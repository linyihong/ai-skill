# 勿在 repo 內對 ~/.cursor 做「反向」連結：會與 bundles 指回 repo 形成循環，IDE 會像無限巢狀。
shared-rules/shared-rules
skills/apk-analysis/apk-analysis

# Generated runtime lookup caches; rebuild from canonical Markdown/YAML sources.
knowledge/runtime/sqlite/*.sqlite
knowledge/runtime/sqlite/*.sqlite-*
knowledge/runtime/sqlite/*.db
knowledge/runtime/sqlite/*.db-*

# Generated runtime state database; mutable per-session state, not committed.
runtime/runtime-state.db
runtime/runtime-state.db-*

# Claude Code 本地設定（per-machine，不進版控）
.claude/settings.local.json
