#!/usr/bin/env bash
# Ai-skill: pre-commit hook for knowledge runtime validation + compiler.
#
# When staged changes touch knowledge/ or validation/ surfaces, run
# validate-knowledge-runtime.rb to catch errors before commit.
#
# When staged changes touch runtime/ YAML sources or compiler rules, run
# compiler-engine.rb to regenerate runtime.db.
#
# Enable with:
#   git config core.hooksPath scripts/git-hooks
set -euo pipefail

ROOT="$(git rev-parse --show-toplevel 2>/dev/null)" || exit 0

CHANGED=$(git diff --cached --name-only)

# --- Compiler: regenerate runtime.db when runtime YAML/compiler sources change ---
if echo "$CHANGED" | grep -qE '^(runtime/(phases|obligations|gates|transactions|router|discovery|compiler|budget|context|guards|health|intelligence|output-governance|pipeline|prompt-artifacts|recovery|scheduler|distributed)/|scripts/git-hooks/pre-commit)'; then
  echo "--- Runtime sources changed, compiling runtime.db ---"
  ruby "${ROOT}/runtime/compiler/compiler-engine.rb" || {
    echo ""
    echo "ERROR: Runtime compiler failed."
    echo "Fix the errors above, then stage and commit again."
    exit 1
  }
fi

# --- Knowledge runtime validation ---
if echo "$CHANGED" | grep -qE '^(knowledge/|validation/|scripts/validate-)'; then
  ruby "${ROOT}/scripts/validate-knowledge-runtime.rb" || {
    echo ""
    echo "ERROR: Knowledge runtime validation failed."
    echo "Run 'ruby scripts/refresh-knowledge-runtime.rb' to regenerate and diagnose."
    echo "Fix the errors above, then stage and commit again."
    exit 1
  }
fi
