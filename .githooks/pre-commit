#!/bin/bash
# Pre-commit hook: Compiler Sync Check + Output Governance Check
#
# 檢查項目：
# 1. Compiler sync：prose source 修改時，對應的 generated YAML 必須同步更新
# 2. Output governance：commit 的檔案是否符合 language policy、sanitization rules
#
# 安裝方式：
#   ./scripts/install-hooks.sh
#
# 跳過檢查（緊急情況）：
#   SKIP_COMPILER_CHECK=1 git commit

set -euo pipefail

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

REPO_ROOT=$(git rev-parse --show-toplevel)
cd "$REPO_ROOT"

# ──────────────────────────────────────────────
# Check 1: Compiler Sync
# ──────────────────────────────────────────────
if [ "${SKIP_COMPILER_CHECK:-}" != "1" ]; then
  # Check if any prose source files are modified
  MODIFIED_SOURCES=false
  COMPILER_RULES="$REPO_ROOT/runtime/compiler/compiler-rules.yaml"

  if [ -f "$COMPILER_RULES" ]; then
    # Get list of staged and unstaged modified files
    CHANGED_FILES=$(git diff --cached --name-only --diff-filter=ACM)
    
    # Check if any changed file matches a compiler source pattern
    while IFS= read -r source_pattern; do
      [ -z "$source_pattern" ] && continue
      # Convert glob pattern to grep pattern
      GREP_PATTERN=$(echo "$source_pattern" | sed 's/\./\\./g' | sed 's/\*/.*/g')
      if echo "$CHANGED_FILES" | grep -qE "$GREP_PATTERN"; then
        MODIFIED_SOURCES=true
        break
      fi
    done < <(ruby -ryaml -e '
      rules = YAML.safe_load(File.read("'"$COMPILER_RULES"'"), permitted_classes: [Date])
      rules["source_target_mapping"]&.each { |m| puts m["source"] }
    ' 2>/dev/null || true)
  fi

  if [ "$MODIFIED_SOURCES" = true ]; then
    echo -e "${YELLOW}📋 Checking compiler sync...${NC}"
    
    if ruby runtime/compiler/compiler-engine.rb --check 2>/dev/null; then
      echo -e "${GREEN}  ✓ All generated surfaces are up to date.${NC}"
    else
      echo -e "${RED}  ✗ Compiler sync check FAILED.${NC}"
      echo ""
      echo -e "${YELLOW}  Prose source files have been modified but generated YAML is not up to date.${NC}"
      echo -e "${YELLOW}  Run the compiler to regenerate:${NC}"
      echo "    ruby runtime/compiler/compiler-engine.rb"
      echo ""
      echo -e "${YELLOW}  To skip this check (emergency only):${NC}"
      echo "    SKIP_COMPILER_CHECK=1 git commit"
      echo ""
      exit 1
    fi
  else
    echo -e "${GREEN}  ✓ No prose sources modified, compiler check skipped.${NC}"
  fi
else
  echo -e "${YELLOW}  ⚠ Compiler check skipped (SKIP_COMPILER_CHECK=1).${NC}"
fi

# ──────────────────────────────────────────────
# Check 2: Output Governance — Language Consistency
# ──────────────────────────────────────────────
if [ "${SKIP_GOVERNANCE_CHECK:-}" != "1" ]; then
  echo -e "${YELLOW}📋 Checking output governance...${NC}"
  
  GOVERNANCE_PASSED=true
  
  # Check 2a: No "Default to English" in committed files
  STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM)
  
  for file in $STAGED_FILES; do
    # Only check .md, .yaml, .yml, .mdc, .rb files
    case "$file" in
      *.md|*.yaml|*.yml|*.mdc|*.rb)
        if git show ":${file}" 2>/dev/null | grep -qi "default to english"; then
          echo -e "${RED}  ✗ $file: Contains 'Default to English' — violates language policy.${NC}"
          GOVERNANCE_PASSED=false
        fi
        ;;
    esac
  done
  
  # Check 2b: Check for absolute local paths (sanitization violation)
  for file in $STAGED_FILES; do
    case "$file" in
      *.md|*.yaml|*.yml)
        # Check for common local absolute paths that should be placeholders
        if git show ":${file}" 2>/dev/null | grep -E "/Users/[A-Za-z]+/" | grep -v "larrylin/Documents/Ai-skill" | head -3 | grep -q .; then
          echo -e "${RED}  ✗ $file: Contains local absolute paths — violates sanitization rules.${NC}"
          echo -e "${YELLOW}    Use placeholders like <AI_SKILL_REPO>, <PROJECT_ROOT>, <WORKSPACE>.${NC}"
          GOVERNANCE_PASSED=false
        fi
        ;;
    esac
  done
  
  if [ "$GOVERNANCE_PASSED" = true ]; then
    echo -e "${GREEN}  ✓ Output governance checks passed.${NC}"
  else
    echo ""
    echo -e "${RED}  ✗ Output governance check FAILED. Fix the issues above and try again.${NC}"
    echo -e "${YELLOW}  To skip this check (emergency only):${NC}"
    echo "    SKIP_GOVERNANCE_CHECK=1 git commit"
    echo ""
    exit 1
  fi
else
  echo -e "${YELLOW}  ⚠ Governance check skipped (SKIP_GOVERNANCE_CHECK=1).${NC}"
fi

echo -e "${GREEN}✅ All pre-commit checks passed.${NC}"
exit 0
