          "type": "array",
          "items": { "type": "string" }
        },
        "unexpected_intelligence": {
          "type": "array",
          "items": { "type": "string" }
        },
        "expected_heuristics": {
          "type": "array",
          "items": { "type": "string" }
        },
        "validation": {
          "type": "array",
          "items": { "type": "string" }
